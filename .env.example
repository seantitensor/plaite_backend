# Plaite Backend Environment Variables

# Path to recipe data (parquet format)
# Required for: plaite sync
RECIPES_PATH=/path/to/all_enriched_recipes.parquet

# Google API Key for image generation
# Required for: plaite generate-image
# Get your key from: https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key-here

# Image generation model
# Options: gemini-3-pro-image-preview (default) or gemini-2.5-flash-image
# - gemini-3-pro-image-preview: Latest/highest quality model
# - gemini-2.5-flash-image: Faster, lower latency model
IMAGE_GENERATION_MODEL=gemini-3-pro-image-preview
